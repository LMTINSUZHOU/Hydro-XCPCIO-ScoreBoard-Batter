{
    "compilerOptions": {
        "target": "es2022",
        "lib": ["esnext"],
        "module": "preserve",
        "esModuleInterop": true,
        "moduleResolution": "bundler",
        "jsx": "react-jsx",
        "sourceMap": false,
        "strict": false,
        "strictBindCallApply": true,
        "resolveJsonModule": true,
        "experimentalDecorators": true,
        "noEmit": true,
        "skipLibCheck": true
    },
    "include": ["**/*.ts", "**/*.tsx"],
    "exclude": ["**/public", "**/frontend", "**/node_modules", "**/bin", "**/dist", "**/__mocks__"]
}
